{
  "name": "timmy-core",
  "version": "0.1.0",
  "private": true,
  "description": "Timmy core — background daemon (HTTP/WS server, LLM orchestration, tools, memory)",
  "license": "UNLICENSED",
  "bin": {
    "timmy": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsup",
    "dev": "tsx watch src/index.ts start",
    "start": "node dist/index.js start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.177",
    "@napi-rs/keyring": "^1.3.0",
    "better-sqlite3": "^12.10.1",
    "effect": "^3.21.3",
    "fastify": "^5.8.5",
    "ink": "^7.0.6",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.2.0",
    "react": "^19.2.7",
    "socket.io": "^4.8.3",
    "timmy-sdk": "workspace:*"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "vitest": "^3.2.6"
  }
}
