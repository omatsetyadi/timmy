{
  "name": "timmy-sdk",
  "version": "0.1.1",
  "description": "Shared types and plugin interface contracts for Timmy",
  "keywords": [
    "timmy",
    "plugin",
    "sdk",
    "agent",
    "tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omatsetyadi/timmy.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/omatsetyadi/timmy#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "vitest": "^3.2.6"
  }
}
